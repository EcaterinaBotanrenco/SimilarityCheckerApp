@page "/profile"
@attribute [Authorize]
@using SimilarityChecker.Shared.Dtos
@using SimilarityChecker.UI.Services
@using Microsoft.AspNetCore.Authorization
@inject IProfileApiClient ProfileApiClient
@inject NavigationManager Nav

<PageTitle>Profilul meu</PageTitle>

@if (_loading)
{
    <div style="max-width:900px;margin:40px auto;">
        <p>Se încarcă profilul...</p>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div style="max-width:900px;margin:40px auto;">
        <div style="background:#ffecec;border:1px solid #ffb3b3;padding:12px;border-radius:10px;">
            @_error
        </div>
    </div>
}
else if (_profile is not null)
{
    <div style="max-width:1000px;margin:40px auto;">
        <div style="border:1px solid #ddd;border-radius:14px;padding:24px;margin-bottom:24px;">
            <h3 style="margin-bottom:16px;">Profilul meu</h3>

            <div style="display:grid;grid-template-columns:1fr 1fr;gap:16px;">
                <div>
                    <strong>Nume complet:</strong><br />
                    @_profile.DisplayName
                </div>
                <div>
                    <strong>Email:</strong><br />
                    @_profile.Email
                </div>
                <div>
                    <strong>Rol:</strong><br />
                    @string.Join(", ", _profile.Roles)
                </div>
                <div>
                    <strong>Număr rapoarte:</strong><br />
                    @_profile.Reports.Count
                </div>
            </div>
        </div>

        <div style="border:1px solid #ddd;border-radius:14px;padding:24px;">
            <h4 style="margin-bottom:16px;">Rapoartele mele</h4>

            @if (_profile.Reports.Count == 0)
            {
                <p>Nu există încă rapoarte generate.</p>
            }
            else
            {
                <div style="overflow-x:auto;">
                    <table class="table">
                        <thead>
                            <tr>
                                <th>Document</th>
                                <th>Data</th>
                                <th>Status</th>
                                <th>Exact</th>
                                <th>Parafrazat</th>
                                <th>Curat</th>
                                <th>Raport</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var r in _profile.Reports)
                            {
                                <tr>
                                    <td>@r.FileName</td>
                                    <td>@r.GeneratedAtUtc.ToLocalTime()</td>
                                    <td>@r.Status</td>
                                    <td>@r.ExactPercent %</td>
                                    <td>@r.ParaphrasePercent %</td>
                                    <td>@r.CleanPercent %</td>

                                    <td>
                                        <button class="btn btn-sm btn-outline-primary"
                                                @onclick="() => DownloadReport(r.DocumentId)">
                                            Descarcă PDF
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </div>
    </div>
}

@code {
    private UserProfileDto? _profile;
    private string? _error;
    private bool _loading = true;

    private void DownloadReport(Guid documentId)
    {
        var url = $"https://localhost:7260/api/internal-scan/report/{documentId}/pdf";
        Nav.NavigateTo(url, forceLoad: true);
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _profile = await ProfileApiClient.GetMyProfileAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
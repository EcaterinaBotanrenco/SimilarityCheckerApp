@page "/signup"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using SimilarityChecker.UI.Authentication
@inject IAuthService Auth
@inject NavigationManager Nav

<PageTitle>Creare cont</PageTitle>

<div style="max-width:520px;margin:60px auto;padding:24px;border:1px solid #ddd;border-radius:12px;">
    <h3 style="margin-bottom:16px;">Creare cont</h3>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div style="background:#ffecec;border:1px solid #ffb3b3;padding:10px;border-radius:10px;margin-bottom:12px;">
            @_error
        </div>
    }

    <EditForm EditContext="_editContext" OnSubmit="HandleSubmit">
        <DataAnnotationsValidator />

        <div style="display:flex; gap:12px;">
            
            <div style="flex:1; margin-bottom:12px;">
                <label>Nume</label>
                <InputText class="form-control" @bind-Value="_model.LastName" />
                <ValidationMessage For="@(() => _model.LastName)" />
            </div>

            <div style="flex:1; margin-bottom:12px;">
                <label>Prenume</label>
                <InputText class="form-control" @bind-Value="_model.FirstName" />
                <ValidationMessage For="@(() => _model.FirstName)" />
            </div>
        </div>

        <div style="margin-bottom:12px;">
            <label>Email</label>
            <InputText class="form-control" @bind-Value="_model.Email" />
            <ValidationMessage For="@(() => _model.Email)" />
        </div>

        <div style="margin-bottom:12px;">
            <label>Parolă</label>
            <InputText class="form-control" type="password" @bind-Value="_model.Password" />
            <ValidationMessage For="@(() => _model.Password)" />
        </div>

        <div style="margin-bottom:12px;">
            <label>Confirmă parola</label>
            <InputText class="form-control" type="password" @bind-Value="_model.ConfirmPassword" />
            <ValidationMessage For="@(() => _model.ConfirmPassword)" />
            @* Show an explicit warning only after the user pressed the create button *@
            @if (_submitAttempted && _model.Password != _model.ConfirmPassword)
            {
                <div class="text-danger" style="margin-top:6px; font-size:12px; font-style: italic;">Reintroduceți parola, parolele nu coincid.</div>
            }
        </div>

        <div style="margin-bottom:16px;">
            <label>Rol</label>
            <InputSelect class="form-control" @bind-Value="_model.Role">
                <option value="">-- alege rolul --</option>
                <option value="Student">Student</option>
                <option value="Teacher">Teacher</option>
            </InputSelect>
            <ValidationMessage For="@(() => _model.Role)" />
        </div>

        <button class="btn btn-success" type="submit" disabled="@_busy">
            @(_busy ? "Se creează..." : "Creează cont")
        </button>

        <button class="btn btn-link" type="button" @onclick='() => Nav.NavigateTo("/login")'>
            Ai deja cont? Autentifică-te
        </button>
    </EditForm>
</div>

@code {
    private SignupModel _model = new();
    private EditContext? _editContext;
    private string? _error;
    private bool _busy;
    private bool _submitAttempted;

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_model);
    }

    private async Task HandleSubmit(EditContext context)
    {
        _error = null;
        _submitAttempted = true;

        // Run validation so ValidationMessage components are populated
        var valid = _editContext?.Validate() ?? context.Validate();

        if (!valid)
        {
            // validation failed (including password mismatch via [Compare])
            return;
        }

        _busy = true;

        var result = await Auth.SignUpAsync(
            firstName: _model.FirstName,
            lastName: _model.LastName,
            email: _model.Email,
            password: _model.Password,
            role: _model.Role);

        _busy = false;

        if (!result.Success)
        {
            _error = result.ErrorMessage ?? "Înregistrare eșuată.";
            return;
        }

        _error = "Cont creat cu succes.";
        Nav.NavigateTo("/", forceLoad: false);
    }

    private sealed class SignupModel
    {
        [Required(ErrorMessage = "Numele este obligatoriu.")]
        [MinLength(2, ErrorMessage = "Numele trebuie să aibă minim 2 caractere.")]
        public string LastName { get; set; } = "";

        [Required(ErrorMessage = "Prenumele este obligatoriu.")]
        [MinLength(2, ErrorMessage = "Prenumele trebuie să aibă minim 2 caractere.")]
        public string FirstName { get; set; } = "";

        [Required(ErrorMessage = "Email-ul este obligatoriu.")]
        [EmailAddress(ErrorMessage = "Email invalid.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Parola este obligatorie.")]
        [MinLength(6, ErrorMessage = "Parola trebuie să aibă minim 6 caractere.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Confirmarea parolei este obligatorie.")]
        public string ConfirmPassword { get; set; } = "";

        [Required(ErrorMessage = "Rolul este obligatoriu.")]
        [RegularExpression("Student|Teacher", ErrorMessage = "Rol invalid.")]
        public string Role { get; set; } = "";
    }
}

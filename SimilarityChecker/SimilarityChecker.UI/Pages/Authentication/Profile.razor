@page "/profile"
@attribute [Authorize]
@using SimilarityChecker.Shared.Dtos
@using SimilarityChecker.UI.Services
@using Microsoft.AspNetCore.Authorization
@using System.IO
@inject IProfileApiClient ProfileApiClient
@inject NavigationManager Nav

<PageTitle>Profilul meu</PageTitle>

@if (_loading)
{
    <div class="app-card">
        <h3 class="card-title">Se încarcă profilul...</h3>
        <p class="card-subtitle">Așteaptă câteva momente până sunt preluate datele utilizatorului.</p>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="alert alert-danger">
        @_error
    </div>
}
else if (_profile is not null)
{
    var latestReport = _profile.Reports
        .OrderByDescending(x => x.GeneratedAtUtc)
        .FirstOrDefault();

    <div class="page-header">
        <h1 class="page-title">Profilul meu</h1>
        <p class="page-subtitle">
            Aici poți vedea datele contului și istoricul rapoartelor generate în sistem.
        </p>
    </div>

    <div class="profile-summary-grid">
        <div class="profile-stat">
            <div class="profile-stat-label">Nume complet</div>
            <div class="profile-stat-value">@_profile.DisplayName</div>
        </div>

        <div class="profile-stat">
            <div class="profile-stat-label">Email</div>
            <div class="profile-stat-value">@_profile.Email</div>
        </div>

        <div class="profile-stat">
            <div class="profile-stat-label">Rol</div>
            <div class="profile-stat-value">@string.Join(", ", _profile.Roles)</div>
        </div>

        <div class="profile-stat">
            <div class="profile-stat-label">Număr rapoarte</div>
            <div class="profile-stat-value">@_profile.Reports.Count</div>
        </div>
    </div>

    <div class="app-card mb-4">
        <h3 class="card-title">Activitate recentă</h3>
        <p class="card-subtitle">Rezumatul ultimei activități realizate în sistem.</p>

        @if (latestReport is null)
        {
            <div class="alert alert-warning mb-0">
                Nu există încă activitate înregistrată.
            </div>
        }
        else
        {
            <div class="profile-info-grid">
                <div class="profile-info-item">
                    <div class="profile-info-label">Ultimul document analizat</div>
                    <div class="profile-info-value">@latestReport.FileName</div>
                </div>

                <div class="profile-info-item">
                    <div class="profile-info-label">Data ultimului raport</div>
                    <div class="profile-info-value">@latestReport.GeneratedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")</div>
                </div>

                <div class="profile-info-item">
                    <div class="profile-info-label">Tip fișier</div>
                    <div class="profile-info-value">@GetFileExtension(latestReport.FileName)</div>
                </div>

                <div class="profile-info-item">
                    <div class="profile-info-label">Acțiune rapidă</div>
                    <div class="profile-info-value">
                        <button class="btn btn-sm btn-primary"
                                @onclick="GoToInternalScan">
                            Scanează document nou
                        </button>
                    </div>
                </div>
            </div>
        }
    </div>

    <div class="app-card">
        <h3 class="card-title">Rapoartele mele</h3>
        <p class="card-subtitle">Lista documentelor analizate și posibilitatea de descărcare a raportului PDF.</p>

        @if (_profile.Reports.Count == 0)
        {
            <div class="alert alert-warning mb-0">
                Nu există încă rapoarte generate.
            </div>
        }
        else
        {
            <div class="table-wrap">
                <table class="report-table">
                    <thead>
                        <tr>
                            <th>Document</th>
                            <th>Data</th>
                            <th>Raport</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var r in _profile.Reports.OrderByDescending(x => x.GeneratedAtUtc))
                        {
                            <tr>
                                <td>@r.FileName</td>
                                <td>@r.GeneratedAtUtc.ToLocalTime().ToString("dd.MM.yyyy")</td>
                                <td>
                                    <button class="btn btn-sm btn-outline-primary"
                                            @onclick="() => DownloadReport(r.DocumentId)">
                                        Descarcă PDF
                                    </button>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        }
    </div>
}

@code {
    private UserProfileDto? _profile;
    private string? _error;
    private bool _loading = true;

    private void DownloadReport(Guid documentId)
    {
        var url = $"https://localhost:7260/api/internal-scan/report/{documentId}/pdf";
        Nav.NavigateTo(url, forceLoad: true);
    }

    private void GoToInternalScan()
    {
        Nav.NavigateTo("/internal-scan");
    }

    private static string GetFileExtension(string? fileName)
    {
        if (string.IsNullOrWhiteSpace(fileName) || !fileName.Contains('.'))
            return "Necunoscut";

        var ext = Path.GetExtension(fileName)?.TrimStart('.').ToUpperInvariant();
        return string.IsNullOrWhiteSpace(ext) ? "Necunoscut" : ext;
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _profile = await ProfileApiClient.GetMyProfileAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
@page "/profile"
@attribute [Authorize]
@using SimilarityChecker.Shared.Dtos
@using SimilarityChecker.UI.Services
@using Microsoft.AspNetCore.Authorization
@using System.IO
@inject IProfileApiClient ProfileApiClient
@inject NavigationManager Nav

<PageTitle>Profilul meu</PageTitle>


@if (_loading)
{
    <div class="profile-loading-card">
        <h3 class="card-title">Se încarcă profilul...</h3>
        <p class="card-subtitle mb-0">
            Așteaptă câteva momente până sunt preluate datele utilizatorului.
        </p>
    </div>
}
else if (!string.IsNullOrWhiteSpace(_error))
{
    <div class="profile-error-card">
        @_error
    </div>
}
else if (_profile is not null)
{
    var latestReport = _profile.Reports
        .OrderByDescending(x => x.GeneratedAtUtc)
        .FirstOrDefault();

    <div class="profile-modern-page">
        <section class="profile-hero">
            <div class="profile-main-card">
                <div class="profile-badge">Profil utilizator</div>

                <h1 class="profile-title">Profilul meu</h1>

                <p class="profile-subtitle">
                    Aici sunt afișate datele contului, rolul utilizatorului și istoricul rapoartelor generate
                    în urma verificării documentelor.
                </p>

                <div class="profile-identity-row">
                    <div class="profile-avatar">
                        @GetInitials(_profile.DisplayName)
                    </div>

                    <div>
                        <div class="profile-name">@_profile.DisplayName</div>
                        <div class="profile-email">@_profile.Email</div>
                        <div class="profile-role-chip">
                            @string.Join(", ", _profile.Roles)
                        </div>
                    </div>
                </div>
            </div>

            <aside class="profile-side-card">
                <div>
                    <div class="profile-side-label">Rapoarte generate</div>
                    <div class="profile-side-value">@_profile.Reports.Count</div>
                    <div class="profile-side-text">
                        Numărul total de documente analizate și rapoarte disponibile pentru descărcare.
                    </div>
                </div>

                <button class="btn btn-primary profile-scan-btn" @onclick="GoToInternalScan">
                    <span class="oi oi-magnifying-glass" aria-hidden="true"></span>
                    Scanează document nou
                </button>
            </aside>
        </section>

        <section class="profile-stat-grid-modern">
            <div class="profile-stat-modern">
                <div class="profile-stat-icon">
                    <span class="oi oi-person" aria-hidden="true"></span>
                </div>
                <div class="profile-stat-label-modern">Nume complet</div>
                <div class="profile-stat-value-modern">@_profile.DisplayName</div>
            </div>

            <div class="profile-stat-modern">
                <div class="profile-stat-icon">
                    <span class="oi oi-envelope-closed" aria-hidden="true"></span>
                </div>
                <div class="profile-stat-label-modern">Email</div>
                <div class="profile-stat-value-modern">@_profile.Email</div>
            </div>

            <div class="profile-stat-modern">
                <div class="profile-stat-icon">
                    <span class="oi oi-badge" aria-hidden="true"></span>
                </div>
                <div class="profile-stat-label-modern">Rol atribuit</div>
                <div class="profile-stat-value-modern">@string.Join(", ", _profile.Roles)</div>
            </div>
        </section>

        <section class="profile-section-card">
            <div class="profile-section-header">
                <div>
                    <div class="profile-section-kicker">Activitate recentă</div>
                    <h3 class="profile-section-title">Ultima analiză realizată</h3>
                    <p class="profile-section-subtitle">
                        Rezumatul celei mai recente verificări efectuate în platformă.
                    </p>
                </div>
            </div>

            @if (latestReport is null)
            {
                <div class="profile-empty-state">
                    Nu există încă activitate înregistrată pentru acest cont.
                </div>
            }
            else
            {
                <div class="profile-activity-grid">
                    <div class="profile-activity-item">
                        <div class="profile-activity-label">Ultimul document analizat</div>
                        <div class="profile-activity-value">@latestReport.FileName</div>
                    </div>

                    <div class="profile-activity-item">
                        <div class="profile-activity-label">Data ultimului raport</div>
                        <div class="profile-activity-value">
                            @latestReport.GeneratedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                        </div>
                    </div>

                    <div class="profile-activity-item">
                        <div class="profile-activity-label">Tip fișier</div>
                        <div class="profile-activity-value">@GetFileExtension(latestReport.FileName)</div>
                    </div>

                    <div class="profile-activity-item">
                        <div class="profile-activity-label">Acțiune rapidă</div>
                        <div class="profile-activity-value">
                            <button class="btn btn-sm btn-primary"
                                    @onclick="GoToInternalScan">
                                Scanează document nou
                            </button>
                        </div>
                    </div>
                </div>
            }
        </section>

        <section class="profile-section-card">
            <div class="profile-section-header">
                <div>
                    <div class="profile-section-kicker">Rapoarte</div>
                    <h3 class="profile-section-title">Rapoartele mele</h3>
                    <p class="profile-section-subtitle">
                        Lista documentelor analizate și posibilitatea de descărcare a raportului PDF.
                    </p>
                </div>
            </div>

            @if (_profile.Reports.Count == 0)
            {
                <div class="profile-empty-state">
                    Nu există încă rapoarte generate.
                </div>
            }
            else
            {
                <div class="profile-table-wrap">
                    <table class="profile-report-table">
                        <thead>
                            <tr>
                                <th>Document</th>
                                <th>Data generării</th>
                                <th>Acțiune</th>
                            </tr>
                        </thead>

                        <tbody>
                            @foreach (var r in _profile.Reports.OrderByDescending(x => x.GeneratedAtUtc))
                            {
                                <tr>
                                    <td>
                                        <div class="profile-file-cell">
                                            <div class="profile-file-icon">
                                                <span class="oi oi-document" aria-hidden="true"></span>
                                            </div>

                                            <div>
                                                <div class="profile-file-name">@r.FileName</div>
                                                <div class="profile-file-type">@GetFileExtension(r.FileName)</div>
                                            </div>
                                        </div>
                                    </td>

                                    <td>
                                        <span class="profile-date-chip">
                                            @r.GeneratedAtUtc.ToLocalTime().ToString("dd.MM.yyyy HH:mm")
                                        </span>
                                    </td>

                                    <td>
                                        <button class="btn btn-sm btn-outline-primary profile-download-btn"
                                                @onclick="() => DownloadReport(r.DocumentId)">
                                            <span class="oi oi-cloud-download" aria-hidden="true"></span>
                                            Descarcă PDF
                                        </button>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            }
        </section>
    </div>
}

@code {
    private UserProfileDto? _profile;
    private string? _error;
    private bool _loading = true;

    private void DownloadReport(Guid documentId)
    {
        var url = $"https://localhost:7260/api/internal-scan/report/{documentId}/pdf";
        Nav.NavigateTo(url, forceLoad: true);
    }

    private void GoToInternalScan()
    {
        Nav.NavigateTo("/internal-scan");
    }

    private static string GetFileExtension(string? fileName)
    {
        if (string.IsNullOrWhiteSpace(fileName) || !fileName.Contains('.'))
        {
            return "Necunoscut";
        }

        var ext = Path.GetExtension(fileName)?.TrimStart('.').ToUpperInvariant();
        return string.IsNullOrWhiteSpace(ext) ? "Necunoscut" : ext;
    }

    private static string GetInitials(string? displayName)
    {
        if (string.IsNullOrWhiteSpace(displayName))
        {
            return "U";
        }

        var parts = displayName
            .Split(' ', StringSplitOptions.RemoveEmptyEntries | StringSplitOptions.TrimEntries);

        if (parts.Length == 1)
        {
            return parts[0].Length >= 2
                ? parts[0].Substring(0, 2).ToUpperInvariant()
                : parts[0].ToUpperInvariant();
        }

        return $"{parts[0][0]}{parts[^1][0]}".ToUpperInvariant();
    }

    protected override async Task OnInitializedAsync()
    {
        try
        {
            _profile = await ProfileApiClient.GetMyProfileAsync();
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _loading = false;
        }
    }
}
@page "/forgot-password"
@using SimilarityChecker.UI.Authentication
@using System.ComponentModel.DataAnnotations
@inject IAuthService Auth
@inject NavigationManager Nav

<PageTitle>Recuperare parolă</PageTitle>

<div class="auth-page">
    <div class="auth-card auth-card-sm">
        <div class="auth-badge">Recuperare acces</div>
        <h1 class="auth-title">Ai uitat parola?</h1>
        <p class="auth-subtitle">
            Introdu adresa de email asociată contului tău. Dacă există un cont pentru acest email, vei primi un link pentru resetarea parolei.
        </p>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-danger mb-3">
                @_error
            </div>
        }

        @if (_requestSent)
        {
            <div class="alert alert-success">
                Dacă există un cont asociat acestei adrese de email, linkul de resetare va fi trimis.
            </div>

            <div style="margin-top:16px;">
                <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/login")'>
                    Înapoi la autentificare
                </button>
            </div>
        }
        else
        {
            <EditForm Model="_model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <InputText class="form-control" @bind-Value="_model.Email" />
                    <ValidationMessage For="@(() => _model.Email)" />
                </div>

                <div class="auth-actions">
                    <button class="btn btn-primary" type="submit" disabled="@_busy">
                        @(_busy ? "Se procesează..." : "Trimite linkul de resetare")
                    </button>

                    <button class="btn btn-link auth-link p-0" type="button" @onclick='() => Nav.NavigateTo("/login")'>
                        Înapoi la login
                    </button>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    private ForgotPasswordModel _model = new();
    private bool _busy;
    private bool _requestSent;
    private string? _error;

    private async Task HandleSubmit()
    {
        _busy = true;

        try
        {
            await Auth.RequestPasswordResetAsync(_model.Email);
            _requestSent = true;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private sealed class ForgotPasswordModel
    {
        [Required(ErrorMessage = "Email-ul este obligatoriu.")]
        [EmailAddress(ErrorMessage = "Email invalid.")]
        public string Email { get; set; } = "";
    }
}
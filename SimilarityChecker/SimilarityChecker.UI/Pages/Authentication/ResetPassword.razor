@page "/reset-password"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.WebUtilities
@using SimilarityChecker.UI.Authentication
@inject IAuthService Auth
@inject NavigationManager Nav

<PageTitle>Resetare parolă</PageTitle>

<div class="auth-page">
    <div class="auth-card auth-card-sm">
        <div class="auth-badge">Resetare parolă</div>
        <h1 class="auth-title">Setează parola nouă</h1>
        <p class="auth-subtitle">
            Introdu parola nouă pentru contul tău.
        </p>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="alert alert-danger mb-3">
                @_error
            </div>
        }

        @if (_success)
        {
            <div class="alert alert-success mb-3">
                Parola a fost resetată cu succes.
            </div>

            <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/login")'>
                Mergi la autentificare
            </button>
        }
        else if (_invalidLink)
        {
            <div class="alert alert-danger mb-3">
                Linkul de resetare este invalid sau incomplet.
            </div>

            <button class="btn btn-primary" @onclick='() => Nav.NavigateTo("/forgot-password")'>
                Cere un link nou
            </button>
        }
        else
        {
            <EditForm Model="_model" OnValidSubmit="HandleSubmit">
                <DataAnnotationsValidator />
                <ValidationSummary />

                <div class="mb-3">
                    <label class="form-label">Email</label>
                    <InputText class="form-control" @bind-Value="_email" disabled />
                </div>

                <div class="mb-3">
                    <label class="form-label">Parolă nouă</label>

                    <div class="password-field">
                        <InputText class="form-control"
                                   type="@(_showPassword ? "text" : "password")"
                                   @bind-Value="_model.NewPassword" />

                        <button type="button"
                                class="password-toggle"
                                @onclick="TogglePasswordVisibility">
                            @(_showPassword ? "Ascunde" : "Arată")
                        </button>
                    </div>

                    <ValidationMessage For="@(() => _model.NewPassword)" />
                </div>

                <div class="mb-4">
                    <label class="form-label">Confirmă parola nouă</label>

                    <div class="password-field">
                        <InputText class="form-control"
                                   type="@(_showConfirmPassword ? "text" : "password")"
                                   @bind-Value="_model.ConfirmPassword" />

                        <button type="button"
                                class="password-toggle"
                                @onclick="ToggleConfirmPasswordVisibility">
                            @(_showConfirmPassword ? "Ascunde" : "Arată")
                        </button>
                    </div>

                    <ValidationMessage For="@(() => _model.ConfirmPassword)" />

                    @if (_submitAttempted && _model.NewPassword != _model.ConfirmPassword)
                    {
                        <div class="validation-message">
                            Reintroduceți parola, parolele nu coincid.
                        </div>
                    }
                </div>

                <div class="auth-actions">
                    <button class="btn btn-primary" type="submit" disabled="@_busy">
                        @(_busy ? "Se procesează..." : "Resetează parola")
                    </button>

                    <button class="btn btn-link auth-link p-0" type="button" @onclick='() => Nav.NavigateTo("/login")'>
                        Înapoi la login
                    </button>
                </div>
            </EditForm>
        }
    </div>
</div>

@code {
    private ResetPasswordModel _model = new();
    private string? _email;
    private string? _token;
    private string? _error;
    private bool _busy;
    private bool _success;
    private bool _invalidLink;
    private bool _submitAttempted;
    private bool _showPassword;
    private bool _showConfirmPassword;

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);
        var query = QueryHelpers.ParseQuery(uri.Query);

        _email = query.TryGetValue("email", out var emailValue) ? emailValue.ToString() : null;
        _token = query.TryGetValue("token", out var tokenValue) ? tokenValue.ToString() : null;

        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_token))
        {
            _invalidLink = true;
        }
    }

    private async Task HandleSubmit()
    {
        _error = null;
        _submitAttempted = true;

        if (_model.NewPassword != _model.ConfirmPassword)
            return;

        if (string.IsNullOrWhiteSpace(_email) || string.IsNullOrWhiteSpace(_token))
        {
            _invalidLink = true;
            return;
        }

        _busy = true;

        try
        {
            await Auth.ResetPasswordAsync(_email, _token, _model.NewPassword);
            _success = true;
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        _showConfirmPassword = !_showConfirmPassword;
    }

    private sealed class ResetPasswordModel
    {
        [Required(ErrorMessage = "Parola nouă este obligatorie.")]
        [MinLength(6, ErrorMessage = "Parola trebuie să aibă minim 6 caractere.")]
        public string NewPassword { get; set; } = "";

        [Required(ErrorMessage = "Confirmarea parolei este obligatorie.")]
        public string ConfirmPassword { get; set; } = "";
    }
}
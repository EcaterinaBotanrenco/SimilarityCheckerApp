@page "/login"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components
@using SimilarityChecker.UI.Authentication
@inject IAuthService Auth
@inject NavigationManager Nav

<PageTitle>Autentificare</PageTitle>


<div class="login-single-page">
    <section class="login-single-card">
        <div class="login-card-top">
            <div class="login-page-badge">Acces în sistem</div>
            <h1 class="login-page-title">Autentificare</h1>
            <p class="login-page-subtitle">
                Introdu datele contului pentru a accesa profilul tău, scanările efectuate
                și rapoartele generate în platformă.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="login-error">
                @_error
            </div>
        }

        <EditForm Model="_model" OnValidSubmit="HandleLogin">
            <DataAnnotationsValidator />

            <div class="login-form-group">
                <label class="form-label">Email</label>
                <InputText class="form-control" @bind-Value="_model.Email" />
                <ValidationMessage For="@(() => _model.Email)" />
            </div>

            <div class="login-form-group">
                <label class="form-label">Parolă</label>

                <div class="password-field">
                    <InputText class="form-control"
                               type="@(_showPassword ? "text" : "password")"
                               @bind-Value="_model.Password" />

                    <button type="button"
                            class="password-toggle"
                            @onclick="TogglePasswordVisibility">
                        @(_showPassword ? "Ascunde" : "Arată")
                    </button>
                </div>

                <ValidationMessage For="@(() => _model.Password)" />
            </div>

            <div class="login-links-row">
                <button class="btn btn-link auth-link p-0 login-link-button"
                        type="button"
                        @onclick='() => Nav.NavigateTo("/forgot-password")'>
                    Ai uitat parola?
                </button>
            </div>

            <div class="login-main-action">
                <button class="btn btn-primary login-submit-btn"
                        type="submit"
                        disabled="@_busy">
                    @(_busy ? "Se autentifică..." : "Intră în cont")
                </button>
            </div>

            <div class="login-bottom-row">
                <span class="login-small-text">Nu ai încă un cont?</span>

                <button class="btn btn-outline-primary"
                        type="button"
                        @onclick='() => Nav.NavigateTo("/signup")'>
                    Creează cont
                </button>
            </div>
        </EditForm>
    </section>
</div>

@code {
    private LoginModel _model = new();
    private string? _error;
    private bool _busy;
    private string? _returnUrl;
    private bool _showPassword;

    protected override void OnInitialized()
    {
        var uri = Nav.ToAbsoluteUri(Nav.Uri);

        if (Microsoft.AspNetCore.WebUtilities.QueryHelpers.ParseQuery(uri.Query)
            .TryGetValue("returnUrl", out var rv))
        {
            _returnUrl = rv.ToString();
        }
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private async Task HandleLogin()
    {
        _error = null;
        _busy = true;

        try
        {
            var result = await Auth.SignInAsync(_model.Email, _model.Password, _model.RememberMe);

            if (!result.Success)
            {
                _error = ExtractErrorMessage(result.ErrorMessage);
                return;
            }

            var target = string.IsNullOrWhiteSpace(_returnUrl)
                ? "/"
                : (_returnUrl.StartsWith("/") ? _returnUrl : "/" + _returnUrl);

            Nav.NavigateTo(target, forceLoad: false);
        }
        catch (Exception ex)
        {
            _error = ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private static string ExtractErrorMessage(string? rawMessage)
    {
        if (string.IsNullOrWhiteSpace(rawMessage))
        {
            return "Autentificare eșuată.";
        }

        try
        {
            using var document = System.Text.Json.JsonDocument.Parse(rawMessage);

            if (document.RootElement.TryGetProperty("errorMessage", out var errorMessage))
            {
                return errorMessage.GetString() ?? "Autentificare eșuată.";
            }

            if (document.RootElement.TryGetProperty("message", out var message))
            {
                return message.GetString() ?? "Autentificare eșuată.";
            }

            if (document.RootElement.TryGetProperty("error", out var error))
            {
                return error.GetString() ?? "Autentificare eșuată.";
            }
        }
        catch
        {
            // Dacă mesajul nu este JSON, îl afișăm ca text simplu.
        }

        return rawMessage;
    }

    private sealed class LoginModel
    {
        [Required(ErrorMessage = "Email-ul este obligatoriu.")]
        [EmailAddress(ErrorMessage = "Email invalid.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Parola este obligatorie.")]
        [MinLength(6, ErrorMessage = "Parola trebuie să aibă minim 6 caractere.")]
        public string Password { get; set; } = "";

        public bool RememberMe { get; set; }
    }
}
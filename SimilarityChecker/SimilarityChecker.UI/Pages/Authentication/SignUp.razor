@page "/signup"
@using System.ComponentModel.DataAnnotations
@using Microsoft.AspNetCore.Components.Forms
@using SimilarityChecker.UI.Authentication
@inject IAuthService Auth
@inject NavigationManager Nav

<PageTitle>Creare cont</PageTitle>

<div class="signup-single-page">
    <section class="signup-single-card">
        <div class="signup-card-top">
            <div class="signup-page-badge">Înregistrare utilizator</div>

            <h1 class="signup-page-title">Creare cont</h1>

            <p class="signup-page-subtitle">
                Completează formularul pentru a crea un cont nou și pentru a utiliza platforma de verificare a similitudinii documentelor.
            </p>
        </div>

        @if (!string.IsNullOrWhiteSpace(_error))
        {
            <div class="signup-error">
                @_error
            </div>
        }

        @if (!string.IsNullOrWhiteSpace(_success))
        {
            <div class="signup-success">
                <h4 class="signup-success-title">@_success</h4>
                <p class="signup-success-text">
                    Vei fi redirecționat automat către pagina de scanare.
                </p>
            </div>
        }
        else
        {
            <EditForm EditContext="_editContext" OnSubmit="HandleSubmit" Context="formContext">
                <DataAnnotationsValidator />

                <div class="signup-form-grid">
                    <div class="signup-form-group">
                        <label class="form-label">Nume</label>
                        <InputText class="form-control" @bind-Value="_model.LastName" disabled="@_busy" />
                        <ValidationMessage For="@(() => _model.LastName)" />
                    </div>

                    <div class="signup-form-group">
                        <label class="form-label">Prenume</label>
                        <InputText class="form-control" @bind-Value="_model.FirstName" disabled="@_busy" />
                        <ValidationMessage For="@(() => _model.FirstName)" />
                    </div>
                </div>

                <div class="signup-form-group">
                    <label class="form-label">Email</label>
                    <InputText class="form-control" @bind-Value="_model.Email" disabled="@_busy" />
                    <ValidationMessage For="@(() => _model.Email)" />
                </div>

                <div class="signup-form-group">
                    <label class="form-label">Parolă</label>

                    <div class="password-field">
                        <InputText class="form-control"
                                   type="@(_showPassword ? "text" : "password")"
                                   @bind-Value="_model.Password"
                                   disabled="@_busy" />

                        <button type="button"
                                class="password-toggle"
                                @onclick="TogglePasswordVisibility"
                                disabled="@_busy">
                            @(_showPassword ? "Ascunde" : "Arată")
                        </button>
                    </div>

                    <ValidationMessage For="@(() => _model.Password)" />
                </div>

                <div class="signup-form-group">
                    <label class="form-label">Confirmă parola</label>

                    <div class="password-field">
                        <InputText class="form-control"
                                   type="@(_showConfirmPassword ? "text" : "password")"
                                   @bind-Value="_model.ConfirmPassword"
                                   disabled="@_busy" />

                        <button type="button"
                                class="password-toggle"
                                @onclick="ToggleConfirmPasswordVisibility"
                                disabled="@_busy">
                            @(_showConfirmPassword ? "Ascunde" : "Arată")
                        </button>
                    </div>

                    <ValidationMessage For="@(() => _model.ConfirmPassword)" />

                    @if (_submitAttempted && _model.Password != _model.ConfirmPassword)
                    {
                        <div class="validation-message">
                            Reintroduceți parola, parolele nu coincid.
                        </div>
                    }
                </div>

                <div class="signup-form-group">
                    <label class="form-label">Rol</label>

                    <InputSelect class="form-select" @bind-Value="_model.Role" disabled="@_busy">
                        <option value="">-- alege rolul --</option>
                        <option value="Student">Student</option>
                        <option value="Teacher">Profesor</option>
                    </InputSelect>

                    <ValidationMessage For="@(() => _model.Role)" />
                </div>

                <div class="signup-actions">
                    <button class="btn btn-success signup-submit-btn" type="submit" disabled="@_busy">
                        @(_busy ? "Se creează contul..." : "Creează cont")
                    </button>
                </div>

                <div class="signup-bottom-row">
                    <span class="signup-small-text">Ai deja un cont?</span>

                    <button class="btn btn-outline-primary"
                            type="button"
                            @onclick='() => Nav.NavigateTo("/login")'
                            disabled="@_busy">
                        Autentifică-te
                    </button>
                </div>
            </EditForm>
        }
    </section>
</div>

@code {
    private SignupModel _model = new();
    private EditContext? _editContext;
    private string? _error;
    private string? _success;
    private bool _busy;
    private bool _submitAttempted;
    private bool _showPassword;
    private bool _showConfirmPassword;

    protected override void OnInitialized()
    {
        _editContext = new EditContext(_model);
    }

    private void TogglePasswordVisibility()
    {
        _showPassword = !_showPassword;
    }

    private void ToggleConfirmPasswordVisibility()
    {
        _showConfirmPassword = !_showConfirmPassword;
    }

    private async Task HandleSubmit(EditContext context)
    {
        _error = null;
        _success = null;
        _submitAttempted = true;

        var valid = _editContext?.Validate() ?? context.Validate();

        if (!valid)
        {
            return;
        }

        if (_model.Password != _model.ConfirmPassword)
        {
            return;
        }

        _busy = true;

        try
        {
            var result = await Auth.SignUpAsync(
                firstName: _model.FirstName,
                lastName: _model.LastName,
                email: _model.Email,
                password: _model.Password,
                role: _model.Role);

            if (!result.Success)
            {
                _error = ExtractErrorMessage(result.ErrorMessage) ?? "Înregistrare eșuată.";
                _busy = false;
                return;
            }

            _success = "Contul a fost creat cu succes. Se face autentificarea...";
            StateHasChanged();

            await Task.Delay(1000);

            var loginResult = await Auth.SignInAsync(_model.Email, _model.Password, rememberMe: false);

            if (!loginResult.Success)
            {
                _error = ExtractErrorMessage(loginResult.ErrorMessage)
                    ?? "Autentificarea automată a eșuat. Te rugăm să te conectezi manual.";

                _success = null;
                _busy = false;
                return;
            }

            _busy = false;
            Nav.NavigateTo("/internal-scan", forceLoad: false);
        }
        catch (Exception ex)
        {
            _error = ExtractErrorMessage(ex.Message) ?? "A apărut o eroare la crearea contului.";
            _busy = false;
        }
    }

    private static string? ExtractErrorMessage(string? rawMessage)
    {
        if (string.IsNullOrWhiteSpace(rawMessage))
        {
            return null;
        }

        try
        {
            using var document = System.Text.Json.JsonDocument.Parse(rawMessage);

            if (document.RootElement.TryGetProperty("errorMessage", out var errorMessage))
            {
                return errorMessage.GetString();
            }

            if (document.RootElement.TryGetProperty("message", out var message))
            {
                return message.GetString();
            }

            if (document.RootElement.TryGetProperty("error", out var error))
            {
                return error.GetString();
            }
        }
        catch
        {
        }

        return rawMessage;
    }

    private sealed class SignupModel
    {
        [Required(ErrorMessage = "Numele este obligatoriu.")]
        [MinLength(2, ErrorMessage = "Numele trebuie să aibă minim 2 caractere.")]
        public string LastName { get; set; } = "";

        [Required(ErrorMessage = "Prenumele este obligatoriu.")]
        [MinLength(2, ErrorMessage = "Prenumele trebuie să aibă minim 2 caractere.")]
        public string FirstName { get; set; } = "";

        [Required(ErrorMessage = "Email-ul este obligatoriu.")]
        [EmailAddress(ErrorMessage = "Email invalid.")]
        public string Email { get; set; } = "";

        [Required(ErrorMessage = "Parola este obligatorie.")]
        [MinLength(6, ErrorMessage = "Parola trebuie să aibă minim 6 caractere.")]
        public string Password { get; set; } = "";

        [Required(ErrorMessage = "Confirmarea parolei este obligatorie.")]
        public string ConfirmPassword { get; set; } = "";

        [Required(ErrorMessage = "Rolul este obligatoriu.")]
        [RegularExpression("Student|Teacher", ErrorMessage = "Rol invalid.")]
        public string Role { get; set; } = "";
    }
}
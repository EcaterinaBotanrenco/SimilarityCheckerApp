@page "/plagiarism-check"
@using Microsoft.AspNetCore.Components.Forms
@using System.IO
@inject NavigationManager Nav
@* @inject IPlagiarismApiClient Api *@

<PageTitle>Plagiarism Checker</PageTitle>

<div class="pc-page">
    <div class="pc-header">
        <div>
            <h1>Plagiarism Checker</h1>
            <p>Încarcă documentul principal și (opțional) documentul de referință. Sistemul calculează similaritatea și generează raport PDF.</p>
        </div>
        <div class="pc-pill">
            <span class="dot"></span>
            <span>@(_result is null ? "Gata pentru verificare" : "Rezultate disponibile")</span>
        </div>
    </div>

    @if (!string.IsNullOrWhiteSpace(_error))
    {
        <div class="pc-alert">
            <strong>Eroare:</strong> @_error
        </div>
    }

    <div class="pc-grid">
        <!-- Upload main -->
        <div class="pc-card">
            <div class="pc-card-title">
                <div class="pc-icon">📄</div>
                <div>
                    <h3>Document pentru verificare</h3>
                    <span class="pc-sub">Obligatoriu • PDF, DOCX, DOC, TXT</span>
                </div>
            </div>

            <div class="pc-drop">
                <InputFile OnChange="OnMainFileChanged" />
                <div class="pc-drop-hint">
                    <div class="pc-drop-big">Trage fișierul aici sau apasă pentru selectare</div>
                    <div class="pc-drop-small">Limită: @FormatBytes(MaxFileSize)</div>
                </div>
            </div>

            @if (_mainFile is not null)
            {
                <div class="pc-file">
                    <div class="pc-file-name">@_mainFile.Name</div>
                    <div class="pc-file-meta">@FormatBytes(_mainFile.Size)</div>
                </div>
            }
            else
            {
                <div class="pc-empty">Niciun fișier selectat</div>
            }
        </div>

        <!-- Upload reference -->
        <div class="pc-card">
            <div class="pc-card-title">
                <div class="pc-icon">📎</div>
                <div>
                    <h3>Document de referință</h3>
                    <span class="pc-sub">Opțional • comparare directă cu documentul principal</span>
                </div>
            </div>

            <div class="pc-drop">
                <InputFile OnChange="OnRefFileChanged" />
                <div class="pc-drop-hint">
                    <div class="pc-drop-big">Selectează documentul de referință</div>
                    <div class="pc-drop-small">Poți lăsa gol dacă nu ai referință</div>
                </div>
            </div>

            @if (_refFile is not null)
            {
                <div class="pc-file">
                    <div class="pc-file-name">@_refFile.Name</div>
                    <div class="pc-file-meta">@FormatBytes(_refFile.Size)</div>
                </div>
            }
            else
            {
                <div class="pc-empty">Fără referință</div>
            }
        </div>
    </div>

    <div class="pc-actions">
        <button class="pc-btn pc-btn-primary" @onclick="RunCheck" disabled="@_busy">
            @if (_busy)
            {
                <span class="pc-spinner"></span>
                <span>Se verifică...</span>
            }
            else
            {
                <span>Verifică</span>
            }
        </button>

        <button class="pc-btn pc-btn-ghost" @onclick="Reset" disabled="@_busy">Resetează</button>
    </div>

    @if (_result is not null)
    {
        <div class="pc-results">
            <div class="pc-card pc-results-main">
                <div class="pc-results-top">
                    <div>
                        <h2>Rezultat general</h2>
                        <p>Similaritate totală calculată pe baza conținutului documentelor.</p>
                    </div>

                    <div class="pc-badge @GetStatusClass(_result.OverallSimilarity, _result.Threshold)">
                        @GetStatusText(_result.OverallSimilarity, _result.Threshold)
                    </div>
                </div>

                <div class="pc-gauge">
                    <div class="pc-gauge-ring" style="@($"--p:{_result.OverallSimilarity};")">
                        <div class="pc-gauge-inner">
                            <div class="pc-gauge-value">@_result.OverallSimilarity%</div>
                            <div class="pc-gauge-sub">prag: @_result.Threshold%</div>
                        </div>
                    </div>

                    <div class="pc-bar">
                        <div class="pc-bar-track">
                            <div class="pc-bar-fill" style="width:@_result.OverallSimilarity%"></div>
                            <div class="pc-bar-threshold" style="left:@_result.Threshold%"></div>
                        </div>
                        <div class="pc-bar-legend">
                            <span>0%</span>
                            <span>100%</span>
                        </div>
                    </div>
                </div>

                <div class="pc-actions pc-results-actions">
                    <button class="pc-btn pc-btn-success" @onclick="DownloadPdf" disabled="@_pdfBusy">
                        @(_pdfBusy ? "Se generează PDF..." : "Generează raport PDF")
                    </button>
                </div>
            </div>

            <div class="pc-card pc-results-list">
                <h3>Potriviri detectate</h3>
                <p class="pc-sub">Top surse/fragmente cu similaritate.</p>

                @if (_result.Matches.Count == 0)
                {
                    <div class="pc-empty">Nu există potriviri.</div>
                }
                else
                {
                    <div class="pc-match-list">
                        @foreach (var m in _result.Matches)
                        {
                            <div class="pc-match">
                                <div class="pc-match-left">
                                    <div class="pc-match-title">@m.SourceName</div>
                                    <div class="pc-match-note">@m.Note</div>
                                </div>
                                <div class="pc-match-right">
                                    <span class="pc-chip">@m.Similarity%</span>
                                </div>
                            </div>
                        }
                    </div>
                }
            </div>
        </div>
    }
</div>

@code {
    private IBrowserFile? _mainFile;
    private IBrowserFile? _refFile;
    private bool _busy;
    private bool _pdfBusy;
    private string? _error;

    // Înlocuiește cu DTO-ul tău real din Shared
    private PlagiarismResultDto? _result;
    private Guid? _lastRunId;

    private const long MaxFileSize = 10 * 1024 * 1024; // 10 MB

    private static readonly string[] AllowedExtensions = new[] { ".pdf", ".docx", ".doc", ".txt" };

    private void OnMainFileChanged(InputFileChangeEventArgs e)
    {
        _error = null;
        var f = e.File;

        if (!IsAllowed(f.Name))
        {
            _error = "Format neacceptat. Acceptate: PDF, DOCX, DOC, TXT.";
            _mainFile = null;
            return;
        }

        if (f.Size > MaxFileSize)
        {
            _error = $"Fișierul depășește limita de {FormatBytes(MaxFileSize)}.";
            _mainFile = null;
            return;
        }

        _mainFile = f;
        _result = null;
        _lastRunId = null;
    }

    private void OnRefFileChanged(InputFileChangeEventArgs e)
    {
        _error = null;
        var f = e.File;

        if (!IsAllowed(f.Name))
        {
            _error = "Format neacceptat. Acceptate: PDF, DOCX, DOC, TXT.";
            _refFile = null;
            return;
        }

        if (f.Size > MaxFileSize)
        {
            _error = $"Fișierul depășește limita de {FormatBytes(MaxFileSize)}.";
            _refFile = null;
            return;
        }

        _refFile = f;
        _result = null;
        _lastRunId = null;
    }

    private async Task RunCheck()
    {
        _error = null;

        if (_mainFile is null)
        {
            _error = "Selectează documentul pentru verificare.";
            return;
        }

        _busy = true;
        try
        {
            // TODO: trimite fișierele către API (multipart/form-data)
            // var response = await Api.CheckAsync(_mainFile, _refFile);
            // _result = response.Result;
            // _lastRunId = response.RunId;

            // DEMO (șterge după ce ai API):
            await Task.Delay(450);
            _lastRunId = Guid.NewGuid();
            _result = new PlagiarismResultDto
            {
                OverallSimilarity = _refFile is null ? 18 : 42,
                Threshold = 25,
                Matches = _refFile is null
                    ? new List<PlagiarismMatchDto>()
                    : new List<PlagiarismMatchDto>
                    {
                        new() { SourceName = _refFile.Name, Similarity = 42, Note = "Comparare directă cu referința." }
                    }
            };
        }
        catch (Exception ex)
        {
            _error = "Eroare la verificare: " + ex.Message;
        }
        finally
        {
            _busy = false;
        }
    }

    private void Reset()
    {
        _error = null;
        _mainFile = null;
        _refFile = null;
        _result = null;
        _lastRunId = null;
    }

    private Task DownloadPdf()
    {
        if (_lastRunId is null)
        {
            _error = "Nu există o verificare finalizată pentru PDF.";
            return Task.CompletedTask;
        }

        _pdfBusy = true;
        Nav.NavigateTo($"/api/plagiarism/report/{_lastRunId}", forceLoad: true);
        _pdfBusy = false;

        return Task.CompletedTask;
    }

    private static bool IsAllowed(string fileName)
    {
        var ext = Path.GetExtension(fileName).ToLowerInvariant();
        return AllowedExtensions.Contains(ext);
    }

    private static string GetStatusText(int score, int threshold)
        => score >= threshold ? "Suspect" : "OK";

    private static string GetStatusClass(int score, int threshold)
        => score >= threshold ? "pc-badge-danger" : "pc-badge-ok";

    private static string FormatBytes(long bytes)
    {
        if (bytes < 1024) return $"{bytes} B";
        if (bytes < 1024 * 1024) return $"{bytes / 1024.0:0.##} KB";
        return $"{bytes / (1024.0 * 1024.0):0.##} MB";
    }

    // DTO demo (în proiectul tău vor veni din SimilarityChecker.Shared)
    private sealed class PlagiarismResultDto
    {
        public int OverallSimilarity { get; set; }
        public int Threshold { get; set; } = 25;
        public List<PlagiarismMatchDto> Matches { get; set; } = new();
    }
    private sealed class PlagiarismMatchDto
    {
        public string SourceName { get; set; } = "";
        public int Similarity { get; set; }
        public string Note { get; set; } = "";
    }
}

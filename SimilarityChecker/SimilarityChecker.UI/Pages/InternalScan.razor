        _textReport = null;
    }

    private static int GetOverallPercent(InternalScanReportDto report)
    {
        var plagPercent = report.ExactPercent + report.ParaphrasePercent;

        if (plagPercent > 100)
        {
            plagPercent = 100;
        }

        if (plagPercent == 0 && report.Fragments is not null && report.Fragments.Count > 0)
        {
            return 1;
        }

        return plagPercent;
    }


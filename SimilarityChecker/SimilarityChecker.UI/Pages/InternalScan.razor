    private static string FormatSize(long bytes)
    {
        if (bytes < 1024)
        {
            return $"{bytes} B";
        }

        double kb = bytes / 1024.0;

        if (kb < 1024)
        {
            return $"{kb:0.##} KB";
        }

        double mb = kb / 1024.0;
        return $"{mb:0.##} MB";
    }

    private int GetManualTextCharacterCount()
    {
        return string.IsNullOrEmpty(_manualText) ? 0 : _manualText.Length;
    }

    private int GetManualTextWordCount()
    {
        if (string.IsNullOrWhiteSpace(_manualText))
        {
            return 0;
        }

        return System.Text.RegularExpressions.Regex.Matches(
            _manualText.Trim(),
            @"\S+").Count;
    }


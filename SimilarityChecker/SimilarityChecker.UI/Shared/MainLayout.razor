@inherits LayoutComponentBase

<HeadOutlet />

<div class="app-shell">
    <aside class="app-sidebar">
        <NavMenu />
    </aside>

    <div class="app-main">
        <header class="app-topbar">
            <div class="topbar-left">
                <div class="topbar-app-label">Platformă academică</div>
                <div class="app-topbar-title">SimilarityChecker</div>
                <div class="app-topbar-subtitle">
                    Verificarea similitudinii documentelor și generarea rapoartelor de analiză
                </div>
            </div>

            <div class="topbar-actions">
                <NavLink href="" class="topbar-link" Match="NavLinkMatch.All">
                    <span class="oi oi-home topbar-icon" aria-hidden="true"></span>
                    Acasă
                </NavLink>
            </div>
        </header>

        <main class="app-content">
            @Body
        </main>
    </div>
</div>
<div class="top-row pl-4 navbar navbar-dark">
    <a class="navbar-brand" href="">SimilarityChecker.UI</a>
    <button class="navbar-toggler" @onclick="ToggleNavMenu">
        <span class="navbar-toggler-icon"></span>
    </button>
</div>

<div class="@NavMenuCssClass" @onclick="ToggleNavMenu">
    <ul class="nav flex-column">
        <li class="nav-item px-3">
            <NavLink href="login" class="nav-link">Login</NavLink>
        </li>
        <li class="nav-item px-3">
            <NavLink href="signup" class="nav-link">Sign Up</NavLink>
        </li>
        <li>
            <a class="nav-link" href="/profile">Profilul meu</a>
        </li>
        <li>
            <NavLink class="nav-link" href="internal-scan">Scanare internă</NavLink>
        </li>

    </ul>
</div>

@code {
    private bool collapseNavMenu = true;

    private string NavMenuCssClass => collapseNavMenu ? "collapse" : null;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }
}

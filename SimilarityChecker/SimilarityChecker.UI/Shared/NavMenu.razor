@using Microsoft.AspNetCore.Components.Authorization
@using SimilarityChecker.UI.Authentication
@inject IAuthService Auth
@inject NavigationManager Nav

<div class="sidebar-header">
    <a class="brand" href="">
        <div class="brand-badge">SC</div>
        <div class="brand-text">
            <span class="brand-title">SimilarityChecker</span>
        </div>
    </a>

    <button class="sidebar-toggle" type="button" @onclick="ToggleNavMenu">
        ☰
    </button>
</div>

<div class="sidebar-menu @(collapseNavMenu ? "is-collapsed" : "")">
    <div class="menu-section-title">Navigare</div>

    <nav class="menu-links">

        <AuthorizeView>
            <NotAuthorized>
                <NavLink href="login" class="menu-link">
                    <span class="oi oi-account-login menu-icon" aria-hidden="true"></span>
                    <span class="menu-link-text">Login</span>
                </NavLink>
            </NotAuthorized>
            <Authorized>
                <a class="menu-link" @onclick="HandleLogout" style="cursor: pointer;">
                    <span class="oi oi-account-logout menu-icon" aria-hidden="true"></span>
                    <span class="menu-link-text">Sign Out</span>
                </a>
            </Authorized>
        </AuthorizeView>

        <NavLink href="profile" class="menu-link">
            <span class="oi oi-person menu-icon" aria-hidden="true"></span>
            <span class="menu-link-text">Profilul meu</span>
        </NavLink>

        <NavLink href="internal-scan" class="menu-link">
            <span class="oi oi-document menu-icon" aria-hidden="true"></span>
            <span class="menu-link-text">Scanare internă</span>
        </NavLink>
    </nav>

    <div class="sidebar-footer">
        <div class="sidebar-footer-label">Sistem de analiză documente</div>
        <div class="sidebar-footer-version">Versiune interfață 1.0</div>
    </div>
</div>

@code {
    private bool collapseNavMenu = true;

    private void ToggleNavMenu()
    {
        collapseNavMenu = !collapseNavMenu;
    }

    private async Task HandleLogout()
    {
        await Auth.SignOutAsync();
        // Redirecționează automat pe pagina de login
        Nav.NavigateTo("/login", forceLoad: true); 
    }
}
  "components": {
    "schemas": {
      "DocumentUploadResponse": {
        "type": "object",
        "properties": {
          "documentId": {
            "type": "string",
            "format": "uuid"
          },
          "fileName": {
            "type": "string",
            "nullable": true
          },
          "wordCount": {
            "type": "integer",
            "format": "int32"
          },
          "sha256": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ForgotPasswordRequestDto": {
        "required": [
          "email"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          }
        },
        "additionalProperties": false
      },
      "FragmentTypeDto": {
        "enum": [
          1,
          2
        ],
        "type": "integer",
        "format": "int32"
      },
      "InternalScanFragmentDto": {
        "type": "object",
        "properties": {
          "type": {
            "$ref": "#/components/schemas/FragmentTypeDto"
          },
          "score": {
            "type": "number",
            "format": "double"
          },
          "sourceTokenStart": {
            "type": "integer",
            "format": "int32"
          },
          "sourceTokenEnd": {
            "type": "integer",
            "format": "int32"
          },
          "refTokenStart": {
            "type": "integer",
            "format": "int32"
          },
          "refTokenEnd": {
            "type": "integer",
            "format": "int32"
          },
          "referenceDocumentId": {
            "type": "string",
            "format": "uuid"
          },
          "referenceFileName": {
            "type": "string",
            "nullable": true
          },
          "sourceSnippet": {
            "type": "string",
            "nullable": true
          },
          "referenceSnippet": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "InternalScanHitDto": {
        "type": "object",
        "properties": {
          "comparedDocumentId": {
            "type": "string",
            "format": "uuid"
          },
          "comparedFileName": {
            "type": "string",
            "nullable": true
          },
          "similarityScore": {
            "type": "number",
            "format": "double"
          }
        },
        "additionalProperties": false
      },
      "InternalScanReportDto": {
        "type": "object",
        "properties": {
          "reportId": {
            "type": "string",
            "format": "uuid"
          },
          "documentId": {
            "type": "string",
            "format": "uuid"
          },
          "generatedAtUtc": {
            "type": "string",
            "format": "date-time"
          },
          "hits": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InternalScanHitDto"
            },
            "nullable": true
          },
          "fragments": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/InternalScanFragmentDto"
            },
            "nullable": true
          },
          "exactPercent": {
            "type": "integer",
            "format": "int32"
          },
          "paraphrasePercent": {
            "type": "integer",
            "format": "int32"
          },
          "cleanPercent": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "InternalScanStartResponse": {
        "type": "object",
        "properties": {
          "reportId": {
            "type": "string",
            "format": "uuid"
          },
          "documentId": {
            "type": "string",
            "format": "uuid"
          },
          "comparedDocuments": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      },
      "LoginRequestDto": {
        "type": "object",
        "properties": {
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "MultipleDocumentUploadResponse": {
        "type": "object",
        "properties": {
          "totalFiles": {
            "type": "integer",
            "format": "int32"
          },
          "importedCount": {
            "type": "integer",
            "format": "int32"
          },
          "skippedCount": {
            "type": "integer",
            "format": "int32"
          },
          "results": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/SingleDocumentImportResult"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "RegisterRequestDto": {
        "type": "object",
        "properties": {
          "firstName": {
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "password": {
            "type": "string",
            "nullable": true
          },
          "role": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "ResetPasswordRequestDto": {
        "required": [
          "email",
          "newPassword",
          "token"
        ],
        "type": "object",
        "properties": {
          "email": {
            "minLength": 1,
            "type": "string",
            "format": "email"
          },
          "token": {
            "minLength": 1,
            "type": "string"
          },
          "newPassword": {
            "minLength": 6,
            "type": "string"
          }
        },
        "additionalProperties": false
      },
      "SingleDocumentImportResult": {
        "type": "object",
        "properties": {
          "fileName": {
            "type": "string",
            "nullable": true
          },
          "isSuccess": {
            "type": "boolean"
          },
          "isDuplicate": {
            "type": "boolean"
          },
          "documentId": {
            "type": "string",
            "format": "uuid",
            "nullable": true
          },
          "wordCount": {
            "type": "integer",
            "format": "int32",
            "nullable": true
          },
          "sha256": {
            "type": "string",
            "nullable": true
          },
          "message": {
            "type": "string",
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UserProfileDto": {
        "type": "object",
        "properties": {
          "userId": {
            "type": "string",
            "nullable": true
          },
          "email": {
            "type": "string",
            "nullable": true
          },
          "firstName": {
            "type": "string",
            "nullable": true
          },
          "lastName": {
            "type": "string",
            "nullable": true
          },
          "displayName": {
            "type": "string",
            "nullable": true
          },
          "roles": {
            "type": "array",
            "items": {
              "type": "string"
            },
            "nullable": true
          },
          "reports": {
            "type": "array",
            "items": {
              "$ref": "#/components/schemas/UserReportItemDto"
            },
            "nullable": true
          }
        },
        "additionalProperties": false
      },
      "UserReportItemDto": {
        "type": "object",
        "properties": {
          "reportId": {
            "type": "string",
            "format": "uuid"
          },
          "documentId": {
            "type": "string",
            "format": "uuid"
          },
          "fileName": {
            "type": "string",
            "nullable": true
          },
          "generatedAtUtc": {
            "type": "string",
            "format": "date-time"
          },
          "status": {
            "type": "string",
            "nullable": true
          },
          "exactPercent": {
            "type": "integer",
            "format": "int32"
          },
          "paraphrasePercent": {
            "type": "integer",
            "format": "int32"
          },
          "cleanPercent": {
            "type": "integer",
            "format": "int32"
          }
        },
        "additionalProperties": false
      }
    }
  }
}